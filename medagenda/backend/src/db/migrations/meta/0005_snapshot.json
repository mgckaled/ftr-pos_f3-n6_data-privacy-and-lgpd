      "columns": {},
      "definition": "select date_trunc('month', \"scheduled_at\") as \"month\", count(*)::int as \"total\", count(*) filter (where \"status\" = 'completed')::int as \"completed\", count(*) filter (where \"status\" = 'cancelled')::int as \"cancelled\", count(*) filter (where \"status\" = 'no_show')::int as \"no_show\" from \"appointments\" where \"appointments\".\"deleted_at\" is null group by date_trunc('month', \"appointments\".\"scheduled_at\")",
      "name": "appointment_stats",
      "schema": "public",
      "isExisting": false,
      "materialized": true
    }
