# MedAgenda — variáveis de ambiente obrigatórias
# LGPD: Art. 46 — nenhum segredo deve ser hardcoded no código-fonte
# Copie este arquivo para .env e preencha com valores reais antes de iniciar o servidor

# Conexão com o banco de dados PostgreSQL
DATABASE_URL=postgresql://medagenda:medagenda@localhost:5432/medagenda

# LGPD: Art. 6º, VII — segredo do JWT (HS256); mínimo 32 caracteres aleatórios em produção
JWT_SECRET=change-me-in-production-use-at-least-32-random-chars

# LGPD: Art. 6º, VII + Art. 46 — chave de criptografia simétrica para pgcrypto (pgp_sym_encrypt)
# Usada para criptografar em repouso: CPF (patients) e campos sensíveis (medical_records)
# Mínimo 32 caracteres aleatórios em produção — perda desta chave = perda irrecuperável dos dados
PGCRYPTO_KEY=change-me-in-production-use-at-least-32-random-chars

# Origem do frontend — usada pelo CORS para evitar CSRF (LGPD Art. 6º, VII)
FRONTEND_URL=http://localhost:5173
